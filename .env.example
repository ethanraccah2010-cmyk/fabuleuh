# =====================================================================
# Variables d'environnement — Réservation Google Agenda
# ---------------------------------------------------------------------
# Copiez ce fichier en « .env » pour tester en local (vercel dev).
# NE JAMAIS committer le vrai .env (il est ignoré par .gitignore).
# En production : déclarez ces 4 variables dans Vercel
# (Project Settings → Environment Variables).
# =====================================================================

# Identifiants OAuth (Google Cloud Console → API & Services → Identifiants)
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx

# Jeton de rafraîchissement obtenu via OAuth Playground (voir README)
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxx

# ID de l'agenda à utiliser (Agenda → Paramètres → « Intégrer l'agenda »
# → Identifiant de l'agenda). Souvent une adresse @group.calendar.google.com
# ou simplement votre adresse Gmail.
GOOGLE_CALENDAR_ID=votre-agenda@group.calendar.google.com
